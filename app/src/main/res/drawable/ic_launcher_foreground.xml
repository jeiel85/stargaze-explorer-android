<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Constellation Lines behind telescope -->
    <path
        android:pathData="M30,30 L54,20 L78,32 L68,60 L40,60 Z"
        android:strokeWidth="1.2"
        android:strokeColor="#7F5CFFFD"
        android:fillColor="#00000000" />
    <path
        android:pathData="M54,20 L68,60 M30,30 L40,60 M78,32 L40,60"
        android:strokeWidth="0.8"
        android:strokeColor="#3F5CFFFD" />

    <!-- Constellation Star points (Glowing) -->
    <path android:pathData="M30,30a2,2 0,1 0,4 0a2,2 0,1 0,-4 0" android:fillColor="#5CFFFD" />
    <path android:pathData="M78,32a2,2 0,1 0,4 0a2,2 0,1 0,-4 0" android:fillColor="#5CFFFD" />
    <path android:pathData="M68,60a2,2 0,1 0,4 0a2,2 0,1 0,-4 0" android:fillColor="#5CFFFD" />
    <path android:pathData="M40,60a2,2 0,1 0,4 0a2,2 0,1 0,-4 0" android:fillColor="#5CFFFD" />

    <!-- Majestic Polaris (North Star) Glowing Core -->
    <path android:pathData="M54,11 L56.2,16.5 L61.7,18.7 L56.2,20.9 L54,26.4 L51.8,20.9 L46.3,18.7 L51.8,16.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="62"
                android:endY="28"
                android:startX="46"
                android:startY="12"
                android:type="linear">
                <item android:color="#FFE259" android:offset="0.0" />
                <item android:color="#FFA751" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- Outer Star Glow (Standard circle representation via path) -->
    <path
        android:pathData="M54,12.7 a6,6 0 1,0 0,12 a6,6 0 1,0 0,-12"
        android:fillColor="#22FFE259" />

    <!-- Sleek Telescope Body -->
    <!-- Tripod Stand legs -->
    <path
        android:pathData="M54,65 L40,88 M54,65 L54,92 M54,65 L68,88"
        android:strokeWidth="3.5"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
    <path
        android:pathData="M45,74 L63,74"
        android:strokeWidth="1.5"
        android:strokeColor="#EAEAEA" />

    <!-- Mount hinge (Standard circle representation via path) -->
    <path
        android:pathData="M54,59 a4,4 0 1,0 0,8 a4,4 0 1,0 0,-8"
        android:fillColor="#E6A15C" />

    <!-- Telescope Tube (Pointing towards top-right / Star) -->
    <!-- Angle is 45 degrees, centered around (54,63). Rear at (38.5,75.5), Front at (64.5,49.5) -->
    <path
        android:pathData="M38.5,75.5 L64.5,49.5"
        android:strokeWidth="7"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="square" />
    <!-- Rear Eyepiece & focus tube -->
    <path
        android:pathData="M32,82 L38.5,75.5"
        android:strokeWidth="4"
        android:strokeColor="#EAEAEA"
        android:strokeLineCap="round" />
    <!-- Front Objective lens hood (colored accent ring) -->
    <path
        android:pathData="M63.5,50.5 L67.5,46.5"
        android:strokeWidth="8"
        android:strokeColor="#E6A15C"
        android:strokeLineCap="square" />

    <!-- Star Glow emitted from lens -->
    <path
        android:pathData="M66,48 L76,38"
        android:strokeWidth="1.5"
        android:strokeColor="#5CFFFD"
        android:strokeLineCap="round" />
</vector>
